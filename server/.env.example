# AgroTrust AI — Server Environment Variables
# Copy to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Trust Score Weights
QUALITY_WEIGHT=0.6
CONFIDENCE_WEIGHT=0.4
TRUST_THRESHOLD=70.0

# Pice Simulator
PICE_TRANSACTION_FEE_PERCENT=1.5
PICE_SETTLEMENT_DELAY_MS=2000
